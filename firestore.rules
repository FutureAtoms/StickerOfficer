rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isValidPack() {
      return request.resource.data.keys().hasAll(['name', 'authorId'])
        && request.resource.data.name is string
        && request.resource.data.name.size() > 0
        && request.resource.data.name.size() <= 100;
    }

    // Users
    match /users/{userId} {
      allow read: if true;
      allow create: if isOwner(userId);
      allow update: if isOwner(userId);
      allow delete: if false;

      match /following/{followId} {
        allow read: if true;
        allow write: if isOwner(userId);
      }

      match /followers/{followerId} {
        allow read: if true;
        allow write: if isAuthenticated();
      }

      match /feed/{feedItemId} {
        allow read: if isOwner(userId);
        allow write: if false; // Cloud Functions only
      }
    }

    // Packs
    match /packs/{packId} {
      allow read: if resource.data.isPublic == true || isOwner(resource.data.authorId);
      allow create: if isAuthenticated() && isValidPack()
        && request.resource.data.authorId == request.auth.uid;
      allow update: if isOwner(resource.data.authorId);
      allow delete: if isOwner(resource.data.authorId);

      match /stickers/{stickerId} {
        allow read: if true;
        allow write: if isAuthenticated()
          && get(/databases/$(database)/documents/packs/$(packId)).data.authorId == request.auth.uid;
      }
    }

    // Likes (composite key: userId_targetId)
    match /likes/{likeId} {
      allow read: if true;
      allow create: if isAuthenticated()
        && request.resource.data.userId == request.auth.uid;
      allow delete: if isAuthenticated()
        && resource.data.userId == request.auth.uid;
    }

    // Categories (read-only, managed by admin)
    match /categories/{categoryId} {
      allow read: if true;
      allow write: if false;
    }

    // Trending (read-only, managed by Cloud Functions)
    match /trending/{packId} {
      allow read: if true;
      allow write: if false;
    }

    // Templates (read-only)
    match /templates/{templateId} {
      allow read: if true;
      allow write: if false;
    }

    // Challenges
    match /challenges/{challengeId} {
      allow read: if true;
      allow write: if false; // Admin/Cloud Functions only

      match /submissions/{packId} {
        allow read: if true;
        allow create: if isAuthenticated();
        allow update: if false;
      }
    }

    // Reports
    match /reports/{reportId} {
      allow create: if isAuthenticated()
        && request.resource.data.reporterId == request.auth.uid;
      allow read: if false;
      allow update: if false;
    }

    // Notifications
    match /notifications/{userId}/items/{notifId} {
      allow read: if isOwner(userId);
      allow update: if isOwner(userId); // Mark as read
      allow write: if false; // Cloud Functions only
    }
  }
}
